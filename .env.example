APP_NAME=D-News
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_LOG_LEVEL=error
APP_URL=http://localhost:8000
SERVERNAME=""

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=news_portal
DB_USERNAME=root
DB_PASSWORD=
DB_OPTIONS="PDO::MYSQL_ATTR_INIT_COMMAND=set names utf8"
DB_ATTRIBUTES="ATTR_ERRMODE=ERRMODE_EXCEPTION"

REMOTE_DB_CONNECTION=mysql
REMOTE_DB_HOST=127.0.0.1
REMOTE_DB_PORT=3306
REMOTE_DB_DATABASE=datalion
REMOTE_DB_USERNAME=homestead
REMOTE_DB_PASSWORD=secret

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_DRIVER=redis
PREFERRED_QUEUE_NAME=

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_DRIVER=sendmail

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

DEBUGBAR_ENABLED=false
